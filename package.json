{
  "name": "finanzas-personales-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "generate": "prisma generate --schema=prisma/schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema=prisma/schema/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema/schema.prisma",
    "db:validate": "prisma validate --schema=prisma/schema/schema.prisma",
    "db:format": "prisma format --schema=prisma/schema/schema.prisma",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^7.8.0",
    "typescript": "^5.8.0"
  }
}
